rules_version = '2';

// Firestore security rules for jpnote-1bdd6
//
// 部署方式（選一）：
//   A. Firebase Console → Firestore Database → Rules → 貼上此檔內容 → 發布
//   B. Firebase CLI: `firebase deploy --only firestore:rules`
//      （需先 `firebase init firestore` 關聯 project jpnote-1bdd6）

service cloud.firestore {
  match /databases/{database}/documents {

    // 使用者私人資料（收藏 / 學習進度 / 複習資料）
    // 結構：users/{uid} → { favorites, quiz_history, srs_data, ... }
    match /users/{userId} {
      allow read, write: if request.auth != null
                        && request.auth.uid == userId;
    }

    // 意見回饋 — 從 contact.html 的表單寫入
    // 必須登入才能 create（防 bot 濫寫），只有你從 Console 讀
    match /feedback/{docId} {
      allow read, update, delete: if false;
      allow create: if
        // 必須登入
        request.auth != null &&
        // uid 必須與 auth.uid 一致（防偽造他人身分）
        request.resource.data.uid == request.auth.uid &&
        // 必要欄位齊全
        request.resource.data.keys().hasAll(['type', 'message', 'uid', 'createdAt']) &&
        // type 必須是預期值
        request.resource.data.type in ['bug', 'feature', 'content', 'other'] &&
        // 訊息非空且 ≤ 5000 字元
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() <= 5000;
    }

    // 訪客 streak 雲端備份（已登入用戶）— 結構併入 users/{uid}.streak，不需要獨立規則

    // 公開累積計數器 — home.html 顯示「已有 X 位學員」
    // 第一個訪客建 doc，之後每位新訪客 +1（前端 localStorage 防同人重複）
    // rules 限制：只能 +1，不能跳號 / 倒退 / 寫入其他 key，避免被洗
    match /stats/{doc} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasOnly(['learners']) &&
        request.resource.data.learners == 1;
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['learners']) &&
        request.resource.data.learners == resource.data.learners + 1;
      allow delete: if false;
    }

    // 預設拒絕：未明確允許的所有路徑皆擋
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
